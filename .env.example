# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy-REPLACE-ME
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=clinic-test-local.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=clinic-test-local
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=clinic-test-local.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# Emulators
EXPO_PUBLIC_USE_EMULATOR=true
EXPO_PUBLIC_EMULATOR_HOST=localhost

# Stripe keys (https://dashboard.stripe.com/test/apikeys)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook secret from `stripe listen` output (optional for checkout, required for webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs (Dashboard -> Products -> Pricing row -> Copy price ID)
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_PREMIUM=price_REPLACE_ME
STRIPE_PRICE_VIP=price_REPLACE_ME
STRIPE_PRICE_EXTRA_STORAGE=price_REPLACE_ME
STRIPE_PRICE_EXTRA_SEATS=price_REPLACE_ME
STRIPE_PRICE_ADVANCED_ANALYTICS=price_REPLACE_ME

# Checkout return URLs (defaults to example.com placeholders)
# STRIPE_CHECKOUT_SUCCESS_URL=https://yourdomain.com/billing/success
# STRIPE_CHECKOUT_CANCEL_URL=https://yourdomain.com/billing/canceled
